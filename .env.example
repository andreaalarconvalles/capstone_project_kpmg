# ARIA local development environment template.
# Copy this file to `.env` and fill only the values you need locally.
# Never commit `.env` or real secret values.

# Optional GitHub token for higher raw-file/API rate limits.
GITHUB_TOKEN=

# Vertex AI project selected in the ARIA settings modal.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT_NUMBER=
GOOGLE_CLOUD_LOCATION=europe-west1
VERTEX_MODEL=gemini-2.5-flash

# Server-side service account JSON for Vercel Functions.
# In Vercel, store the full JSON or base64-encoded JSON as a sensitive environment variable.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional override for raw GitHub data fetches.
ARIA_GITHUB_OWNER=lukatcheishvili
ARIA_GITHUB_REPO=capstone_project_kpmg
ARIA_GITHUB_BRANCH=main
ARIA_DATA_CACHE_TTL_MS=1200000
